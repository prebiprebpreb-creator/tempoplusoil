# ---- SMTP credentials used by Nodemailer to send order emails ----
# Recommended: create a Gmail App Password (Google Account > Security > 2-Step Verification > App passwords)
# and use that value as SMTP_PASS.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tempoplus.pr1@gmail.com
SMTP_PASS=your_16_char_app_password_here

# Where order emails will be delivered
ORDER_TO=rronprebreza@gmail.com,tempoplus.pr1@gmail.com

# From address shown to recipients
MAIL_FROM="Tempo Plus Orders <tempoplus.pr1@gmail.com>"

PORT=3000
